{
  "name": "fresnel",
  "private": true,
  "version": "0.1.0",
  "description": "AI-powered code review for GitHub",
  "author": "Mitchell Hynes",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:mac": "vite build && electron-builder --mac --publish never --config electron-builder.json",
    "electron:build:win": "vite build && electron-builder --win --config electron-builder.json",
    "electron:build:linux": "vite build && electron-builder --linux --config electron-builder.json"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.69",
    "@headlessui/react": "^2.2.9",
    "@phosphor-icons/react": "^2.1.10",
    "ai-elements": "^1.8.1",
    "framer-motion": "^12.29.2",
    "mixpanel-browser": "^2.74.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "react-scroll-to-bottom": "^4.2.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "vite": "^6.0.7",
    "wait-on": "^9.0.3"
  }
}

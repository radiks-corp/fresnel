{
  "name": "fresnel-backend",
  "version": "1.0.0",
  "description": "Fresnel API backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:sentry": "tsc && sentry-cli sourcemaps upload --org=fresnel-un --project=node-express ./dist",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.34",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@sentry/node": "^10.39.0",
    "@sentry/profiling-node": "^10.39.0",
    "ai": "^6.0.66",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "mongoose": "^8.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sentry/cli": "^3.2.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}

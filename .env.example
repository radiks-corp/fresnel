# MongoDB Configuration
MONGO_ROOT_USERNAME=fresnel
MONGO_ROOT_PASSWORD=your_password_here
MONGO_DATABASE=fresnel

# Backend Configuration
NODE_ENV=development
PORT=3001
MONGODB_URI=mongodb://fresnel:your_password_here@localhost:27017/fresnel?authSource=admin
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# Frontend Configuration
# Use localhost for local dev, backend for Docker
VITE_API_URL=http://localhost:3001

# GitHub OAuth Configuration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# AI Provider Configuration
# Default Anthropic API key (used when users don't provide their own key)
# ANTHROPIC_API_KEY=your_anthropic_api_key
# Users can bring their own API keys via the Settings UI (BYOK mode)

# Sentry Configuration (optional)
# Leave empty to disable Sentry in development
# SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
# SENTRY_DSN=your_sentry_dsn_here

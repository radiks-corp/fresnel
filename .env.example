# MongoDB Configuration
MONGO_ROOT_USERNAME=fresnel
MONGO_ROOT_PASSWORD=your_password_here
MONGO_DATABASE=fresnel

# Backend Configuration
NODE_ENV=development
PORT=3001
MONGODB_URI=mongodb://fresnel:your_password_here@localhost:27017/fresnel?authSource=admin
FRONTEND_URL=http://localhost:5173

# GitHub App Configuration
GITHUB_APP_ID=your_app_id
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# Frontend Configuration
# Use localhost for local dev, backend for Docker
VITE_API_URL=http://localhost:3001
